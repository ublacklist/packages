{
  "extends": "../../tsconfig.json",

  "include": ["src"],
  "exclude": ["**/*.test.ts"],

  "compilerOptions": {
    // Modules
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "src",

    // Emit
    "declaration": true,
    "noEmit": false,
    "outDir": "dist"
  }
}
